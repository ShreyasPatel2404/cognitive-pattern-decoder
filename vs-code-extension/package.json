{
  "name": "cognitive-decoder",
  "displayName": "Cognitive Coding Decoder",
  "description": "VS Code extension to collect cognitive coding behavior",
  "version": "0.0.6",
  "publisher": "maitreypatel",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./src/extension.js",
  "activationEvents": [
    "onStartupFinished",
    "onCommand:cognitiveDecoder.login",
    "onCommand:cognitiveDecoder.selectProject",
    "onCommand:cognitiveDecoder.endSession"
  ],
  "contributes": {
    "commands": [
      {
        "command": "cognitiveDecoder.login",
        "title": "Cognitive Decoder: Login"
      },
      {
        "command": "cognitiveDecoder.selectProject",
        "title": "Cognitive Decoder: Select Project"
      },
      {
        "command": "cognitiveDecoder.endSession",
        "title": "Cognitive Decoder: End Session"
      }
    ],
    "configuration": {
      "title": "Cognitive Pattern Decoder",
      "properties": {
        "cognitivePatternDecoder.serverUrl": {
          "type": "string",
          "default": "http://localhost:5000",
          "description": "Backend server URL"
        },
        "cognitivePatternDecoder.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable telemetry collection"
        },
        "cognitiveDecoder.backendUrl": {
          "type": "string",
          "default": "http://localhost:5000",
          "description": "Backend API base URL (legacy - use cognitivePatternDecoder.serverUrl)"
        }
      }
    }
  },
  "scripts": {
    "start": "node src/extension.js",
    "vscode:prepublish": "npm run compile",
    "compile": "echo \"No compile step needed for JS source\"",
    "watch": "echo \"No watch step needed for JS source\"",
    "package": "vsce package",
    "lint": "eslint src"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0"
  }
}
